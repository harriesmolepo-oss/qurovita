PORT=3000
DATABASE_URL=postgresql://qurovita:qurovita_dev@localhost:5433/qurovita
NODE_ENV=development
JWT_SECRET=
REDIS_URL=
SENTRY_DSN=

# Production only — leave blank in dev (keys loaded from .keys/ instead)
AWS_KMS_KEY_ID=
AWS_KMS_WRAP_KEY_ID=
AWS_REGION=af-south-1

# 🔴 HUMAN ACTION NEEDED — AWS account provisioning required before T3.3 can run live.
# T3.1/T3.2 (OCR service + tests) use mocked Textract — no real credentials needed.
# T3.3 (POST /documents route + S3 upload) requires a provisioned IAM user with:
#   • AmazonTextractFullAccess (or scoped to AnalyzeDocument only)
#   • s3:PutObject on the qurovita-documents bucket (af-south-1)
# Set these in .env.local (never commit actual values):
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=qurovita-documents
